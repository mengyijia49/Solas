{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: unittest",
      "type": "debugpy",
      "request": "launch",
      "module": "unittest",
      "args": [
        "discover",
        "-s",
        "test"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/python"
      },
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "C++: unittest through Python",
      "type": "cppdbg",
      "request": "launch",
      "program": "/usr/bin/python3",
      "args": [
        "-m",
        "unittest",
        "discover",
        "-s",
        "test"
      ],
      "cwd": "${workspaceFolder}",
      "environment": [
        {
          "name": "PYTHONPATH",
          "value": "${workspaceFolder}/python"
        },
        {
          "name": "SOLAS_LIBRARY_PATH",
          "value": "${workspaceFolder}/build/linux/x86_64/debug/libsolas.so"
        }
      ],
      "externalConsole": false,
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}
